# AI Service Configuration
PORT=4723
NODE_ENV=development

# BlazeAI Configuration
BLAZEAI_API_URL=https://blazeai.boxu.dev
BLAZEAI_API_KEY=your_blazeai_api_key_here
BLAZEAI_DAILY_QUOTA=1000
BLAZEAI_QUOTA_THRESHOLD=950

# Ollama Configuration
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6345
REDIS_PASSWORD=

# PostgreSQL Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5445/ostora

# Kafka Configuration
KAFKA_BROKERS=localhost:9095
KAFKA_CLIENT_ID=ai-service
KAFKA_GROUP_ID=ai-service-group

# BullMQ Configuration
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6345

# Rate Limiting
RATE_LIMIT_FREE=10
RATE_LIMIT_PREMIUM=100
RATE_LIMIT_B2B=1000
