# Payment Service Environment Variables

# Service
PORT=4724
NODE_ENV=development

# Database
DATABASE_URL=postgresql://ostora:ostora123@localhost:5445/ostora_payment?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6345
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=localhost:9095
KAFKA_CLIENT_ID=payment-service
KAFKA_GROUP_ID=payment-service-group

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_PREMIUM_MONTHLY=price_premium_monthly_id
STRIPE_PRICE_PREMIUM_ANNUAL=price_premium_annual_id
STRIPE_PRICE_B2B_STARTER=price_b2b_starter_id
STRIPE_PRICE_B2B_PRO=price_b2b_pro_id

# PayPal (for future implementation)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# CORS
CORS_ORIGIN=http://localhost:3000

# JWT (for auth validation)
JWT_SECRET=your_jwt_secret_key_here
