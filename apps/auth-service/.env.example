# Server
PORT=4718
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5445/ostora?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6345
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_BROKER=localhost:9095

# JWT
JWT_ACCESS_SECRET=your_jwt_secret_key_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900
