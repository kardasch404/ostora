<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <style>
    body { font-family: 'Courier New', monospace; color: #111; margin: 0; }
    .page { padding: 26px; }
    h1 { margin: 0; font-size: 26px; }
    .subtitle { margin-top: 4px; color: #444; }
    .block { margin-top: 16px; }
    .block h2 { margin: 0 0 6px; font-size: 13px; text-transform: uppercase; }
    .entry { margin-bottom: 8px; }
    .meta { color: #555; font-size: 12px; }
  </style>
</head>
<body>
  <div class="page">
    <h1>{{profile.fullName}}</h1>
    <div class="subtitle">{{profile.title}} | {{profile.city}}, {{profile.country}}</div>

    <div class="block">
      <h2>{{labels.summary}}</h2>
      <div>{{profile.bio}}</div>
    </div>

    <div class="block">
      <h2>{{labels.experience}}</h2>
      {{#each profile.experience}}
        <div class="entry">
          <div>{{title}}{{role}} @ {{company}}</div>
          <div class="meta">{{startDate}} - {{#if current}}Present{{else}}{{endDate}}{{/if}}</div>
        </div>
      {{/each}}
    </div>

    <div class="block">
      <h2>{{labels.education}}</h2>
      {{#each profile.education}}
        <div class="entry">
          <div>{{institution}} - {{degree}}</div>
          <div class="meta">{{startDate}} - {{#if current}}Present{{else}}{{endDate}}{{/if}}</div>
        </div>
      {{/each}}
    </div>

    <div class="block">
      <h2>{{labels.skills}}</h2>
      <div>{{#each profile.skills}}{{name}}{{#unless @last}} | {{/unless}}{{/each}}</div>
    </div>

    <div class="block">
      <h2>{{labels.languages}}</h2>
      <div>{{#each profile.languages}}{{name}}{{#unless @last}} | {{/unless}}{{/each}}</div>
    </div>

    <div class="meta">{{labels.generatedBy}} - {{generatedAt}}</div>
  </div>
</body>
</html>
