# ==================== APPLICATION ====================
NODE_ENV=development
APP_NAME=Ostora
APP_VERSION=1.0.0

# ==================== DATABASES ====================
# PostgreSQL (Main DB)
DATABASE_URL=postgresql://ostora:ostora_secret_2024@localhost:5445/ostora_db
POSTGRES_USER=ostora
POSTGRES_PASSWORD=ostora_secret_2024
POSTGRES_DB=ostora_db

# MySQL (Analytics)
MYSQL_HOST=localhost
MYSQL_PORT=3345
MYSQL_USER=ostora
MYSQL_PASSWORD=ostora_secret_2024
MYSQL_DATABASE=ostora_analytics

# MongoDB (Logs)
MONGODB_URI=mongodb://ostora:ostora_secret_2024@localhost:27045/ostora_logs?authSource=admin

# Redis (Cache & Sessions)
REDIS_HOST=localhost
REDIS_PORT=6345
REDIS_PASSWORD=ostora_redis_2024
REDIS_TTL=3600

# Elasticsearch (Search)
ELASTICSEARCH_NODE=http://localhost:9245
ELASTICSEARCH_INDEX_PREFIX=ostora

# ==================== MESSAGE BROKER ====================
KAFKA_BROKER=localhost:9095
KAFKA_CLIENT_ID=ostora-platform
KAFKA_GROUP_ID=ostora-consumer-group

# ==================== MICROSERVICES PORTS ====================
API_GATEWAY_PORT=4717
AUTH_SERVICE_PORT=4718
USER_SERVICE_PORT=4719
JOB_SERVICE_PORT=4720
EMAIL_SERVICE_PORT=4721
SCRAPING_SERVICE_PORT=4722
AI_SERVICE_PORT=4723
PAYMENT_SERVICE_PORT=4724
ANALYTICS_SERVICE_PORT=4725
B2B_SERVICE_PORT=4726
NOTIFICATION_SERVICE_PORT=4727
NETWORKING_SERVICE_PORT=4728

# ==================== JWT & SECURITY ====================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2024
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-2024
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
BCRYPT_ROUNDS=12

# ==================== OAUTH PROVIDERS ====================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4717/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:4717/auth/github/callback

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_CALLBACK_URL=http://localhost:4717/auth/linkedin/callback

# ==================== EMAIL SERVICE ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@ostora.com
EMAIL_FROM_NAME=Ostora Platform

# AWS SES (Production)
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY=your-aws-access-key
AWS_SES_SECRET_KEY=your-aws-secret-key

# ==================== PAYMENT PROVIDERS ====================
# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# ==================== AI SERVICES ====================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000

# ==================== SCRAPING ====================
SCRAPING_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
SCRAPING_TIMEOUT=30000
SCRAPING_MAX_RETRIES=3
SCRAPING_RATE_LIMIT=10

# ==================== RATE LIMITING ====================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ==================== CORS ====================
CORS_ORIGIN=http://localhost:3000,http://localhost:4717
CORS_CREDENTIALS=true

# ==================== FILE UPLOAD ====================
MAX_FILE_SIZE=10485760
UPLOAD_DEST=./uploads
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.jpeg,.png

# ==================== AWS S3 (File Storage) ====================
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=ostora-uploads
AWS_S3_ACCESS_KEY=your-aws-access-key
AWS_S3_SECRET_KEY=your-aws-secret-key

# ==================== LOGGING ====================
LOG_LEVEL=debug
LOG_DIR=./logs
LOG_MAX_FILES=14d

# ==================== MONITORING ====================
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# ==================== B2B ENTERPRISE ====================
B2B_API_KEY_PREFIX=ostora_b2b_
B2B_RATE_LIMIT_BASIC=1000
B2B_RATE_LIMIT_PRO=5000
B2B_RATE_LIMIT_ENTERPRISE=50000

# ==================== WEBSOCKET ====================
WS_CORS_ORIGIN=http://localhost:3000
WS_PATH=/socket.io

# ==================== 2FA ====================
TWO_FACTOR_APP_NAME=Ostora
TWO_FACTOR_ISSUER=Ostora Platform

# ==================== SESSION ====================
SESSION_SECRET=your-session-secret-key-change-in-production
SESSION_MAX_AGE=86400000

# ==================== FRONTEND URL ====================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4717
