{
  "name": "ostora",
  "version": "1.0.0",
  "description": "Enterprise Job Platform - Microservices Architecture",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "start:gateway": "nx serve api-gateway",
    "start:auth": "nx serve auth-service",
    "start:user": "nx serve user-service",
    "start:job": "nx serve job-service",
    "start:scraping": "nx serve scraping-service",
    "start:email": "nx serve email-service",
    "start:ai": "nx serve ai-service",
    "start:payment": "nx serve payment-service",
    "start:analytics": "nx serve analytics-service",
    "start:b2b": "nx serve b2b-service",
    "start:notification": "nx serve notification-service",
    "start:networking": "nx serve networking-service",
    "build": "tsc --noEmit",
    "test": "jest",
    "test:auth": "jest --testPathPattern=auth-service",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"**/*.ts\" --fix",
    "lint:check": "eslint \"**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "commit-setup": "git add . && git commit -m \"chore: initial project setup with microservices architecture, devops config, and infrastructure\" && git push origin ostora-config"
  },
  "dependencies": {
    "@apollo/server": "^4.9.5",
    "@aws-sdk/client-s3": "^3.1011.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@nestjs/apollo": "^12.0.11",
    "@nestjs/axios": "^3.0.1",
    "@nestjs/bull": "^10.0.1",
    "@nestjs/cache-manager": "^2.1.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/graphql": "^12.0.11",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/throttler": "^5.1.1",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.8.1",
    "@types/pdfkit": "^0.17.5",
    "axios": "^1.6.5",
    "bcrypt": "^5.1.1",
    "bull": "^4.12.0",
    "cache-manager": "^5.3.2",
    "cache-manager-ioredis-yet": "^2.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.6",
    "dayjs": "^1.11.10",
    "express": "^5.2.1",
    "graphql": "^16.8.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "ms": "^2.1.3",
    "mysql2": "^3.20.0",
    "nest-winston": "^1.9.4",
    "nodemailer": "^6.9.7",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-linkedin-oauth2": "^2.0.0",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.18.0",
    "prisma": "^5.8.1",
    "qrcode": "^1.5.3",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "socket.io": "^4.6.0",
    "speakeasy": "^2.0.0",
    "stripe": "^14.10.0",
    "uuid": "^9.0.1",
    "uuidv7": "^0.6.3",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@nrwl/nest": "^17.2.8",
    "@nrwl/workspace": "^17.2.8",
    "@playwright/test": "^1.40.1",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.38",
    "@types/stripe": "^8.0.416",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "eslint": "^8.56.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nx": "^17.2.8",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
