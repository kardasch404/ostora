generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== RBAC ====================
model Role {
  id          String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId     String?  @db.Uuid
  action     String
  resource   String
  resourceId String?  @db.Uuid
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now()) @db.Timestamptz

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model UserSession {


  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])

  @@map("user_sessions")
}

// ==================== USER & AUTH ====================
model User {


  @@index([userId])
  @@map("profiles")
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
  RECRUITERS_ONLY
}

model Session {


  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model RefreshToken {


  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model OAuthProvider {


  @@unique([provider, providerId])
  @@index([userId])
  @@map("oauth_providers")
}

model Document {


  @@index([userId])
  @@index([type])
  @@map("documents")
}

enum DocumentType {
  CV
  RESUME
  COVER_LETTER
  CERTIFICATE
  PORTFOLIO
  OTHER
}

model Job {

  @@index([status])
  @@index([type])
  @@index([level])
  @@index([category])
  @@index([country])
  @@index([remote])
  @@index([createdAt])
  @@map("jobs")
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
  TEMPORARY
}

enum JobLevel {
  ENTRY
  JUNIOR
  MID
  SENIOR
  LEAD
  MANAGER
  DIRECTOR
  EXECUTIVE
}

enum JobStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  FILLED
  DRAFT
}

model JobApplication {

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@index([status])
  @@map("job_applications")
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  INTERVIEW
  OFFER
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model SavedJob {


  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@map("saved_jobs")
}

model JobAlert {

  @@index([userId])
  @@index([active])
  @@map("job_alerts")
}

model Subscription {


  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  TRIALING
}

model Payment {

  @@index([userId])
  @@index([status])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
}

model Notification {


  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  JOB_MATCH
  APPLICATION_UPDATE
  MESSAGE
  PAYMENT
  SYSTEM
  ALERT
}

model UserActivity {


  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("user_activities")
}

model NetworkingAction {


  @@index([userId])
  @@index([status])
  @@map("networking_actions")
}

enum NetworkingType {
  CONNECTION_REQUEST
  MESSAGE
  INMAIL
  EMAIL_OUTREACH
}

enum NetworkingStatus {
  PENDING
  SENT
  ACCEPTED
  REJECTED
  NO_RESPONSE
}

model B2BClient {


  @@index([apiKey])
  @@map("b2b_clients")
}
